# ── LLM Provider ──────────────────────────────────────────────
# Auto-detected: if OPENAI_API_KEY is set → openai, otherwise → ollama
# Override explicitly with: ollama | openai
# LLM_PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-5
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Ollama (used when LLM_PROVIDER=ollama or no API key set) ─
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=CognitiveComputations/dolphin-mistral-nemo:12b

# ── Server ────────────────────────────────────────────────────
# PORT=8000
# WS_PORT=18789
# HOST=0.0.0.0
# CORS_ORIGIN=http://localhost:3000
# LOG_LEVEL=info
# JWT_SECRET=jait-dev-secret-change-in-production

# ── Web Search Providers (web.search tool) ───────────────────
# Auto priority: BRAVE_API_KEY -> PERPLEXITY/OPENROUTER -> XAI -> GEMINI -> MOONSHOT -> OPENAI_API_KEY
# If provider-specific API keys are missing, web.search falls back to OpenAI web_search.

# OpenAI web_search fallback/default
# OPENAI_WEB_SEARCH_MODEL=gpt-5

# Brave Search
# BRAVE_API_KEY=

# Perplexity (direct) or OpenRouter (Perplexity models)
# PERPLEXITY_API_KEY=
# OPENROUTER_API_KEY=
# PERPLEXITY_MODEL=sonar-pro
# PERPLEXITY_OPENROUTER_MODEL=perplexity/sonar-pro

# xAI Grok
# XAI_API_KEY=
# GROK_MODEL=grok-4-1212

# Google Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Moonshot Kimi
# MOONSHOT_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# KIMI_MODEL=moonshot-v1-128k

# ── Faster Whisper (local STT) ───────────────────────────────
# URL of the local Faster Whisper HTTP server.
# Start with: cd packages/gateway/whisper-server && python server.py
# WHISPER_URL=http://localhost:8178
