# ── LLM Provider ──────────────────────────────────────────────
# Auto-detected: if OPENAI_API_KEY is set → openai, otherwise → ollama
# Override explicitly with: ollama | openai
# LLM_PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-5
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Ollama (used when LLM_PROVIDER=ollama or no API key set) ─
# OLLAMA_URL=http://192.168.178.60:11434
# OLLAMA_MODEL=CognitiveComputations/dolphin-mistral-nemo:12b

# ── Server ────────────────────────────────────────────────────
# PORT=8000
# WS_PORT=18789
# HOST=0.0.0.0
# CORS_ORIGIN=http://localhost:3000
# LOG_LEVEL=info
# JWT_SECRET=jait-dev-secret-change-in-production
