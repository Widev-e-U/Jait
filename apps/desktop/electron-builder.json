{
  "appId": "dev.jait.desktop",
  "productName": "Jait",
  "npmRebuild": false,
  "directories": {
    "output": "release",
    "buildResources": "assets"
  },
  "icon": "assets/icon-1024.png",
  "files": [
    "dist/**/*",
    "assets/**/*"
  ],
  "extraResources": [
    {
      "from": "../web/dist",
      "to": "web",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "artifactName": "Jait-${version}-${arch}-setup.${ext}"
  },
  "portable": {
    "artifactName": "Jait-${version}-${arch}-portable.${ext}"
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.developer-tools",
    "artifactName": "Jait-${version}-${arch}.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Development",
    "artifactName": "Jait-${version}-${arch}.${ext}"
  },
  "publish": {
    "provider": "github",
    "owner": "Widev-e-U",
    "repo": "Jait"
  }
}
