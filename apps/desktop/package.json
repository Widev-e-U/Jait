{
  "name": "@jait/desktop",
  "version": "0.1.25",
  "description": "Jait AI desktop app",
  "author": {
    "name": "JakobWl",
    "email": "jakob@jait.dev"
  },
  "homepage": "https://github.com/JakobWl/Jait",
  "private": true,
  "type": "module",
  "main": "dist/electron-main.js",
  "scripts": {
    "dev": "bun run build:main && electron dist/electron-main.js",
    "dev:watch": "tsc --watch & electron dist/electron-main.js",
    "build": "tsc",
    "build:main": "tsc",
    "typecheck": "tsc --noEmit",
    "pack": "electron-builder --dir --config electron-builder.json",
    "dist": "electron-builder --config electron-builder.json",
    "build:win": "electron-builder --config electron-builder.json --win --publish never",
    "build:mac": "electron-builder --config electron-builder.json --mac --publish never",
    "build:linux": "electron-builder --config electron-builder.json --linux --publish never"
  },
  "dependencies": {
    "@jait/api-client": "workspace:*",
    "@jait/shared": "workspace:*",
    "@jait/ui-shared": "workspace:*",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.10.2",
    "electron": "35.7.5",
    "electron-builder": "^25.1.8"
  }
}
