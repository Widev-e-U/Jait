{
  "name": "@jait/mobile",
  "version": "0.1.2",
  "private": true,
  "main": "App.tsx",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "cap:init": "cap init Jait dev.jait.mobile --web-dir ../../apps/web/dist",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "dev:android": "bun run --filter '@jait/web' build && cap sync android && cap open android",
    "dev:ios": "bun run --filter '@jait/web' build && cap sync ios && cap open ios",
    "dev": "expo start",
    "dev:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/keyboard": "6",
    "@capacitor/screen-reader": "^6.0.0",
    "@jait/api-client": "workspace:*",
    "@jait/shared": "workspace:*",
    "@jait/ui-shared": "workspace:*",
    "@react-native/assets-registry": "0.74.87",
    "expo": "^51.0.39",
    "expo-asset": "~10.0.10",
    "expo-constants": "~16.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.10",
    "expo-keep-awake": "~13.0.2",
    "expo-modules-core": "~1.12.26",
    "react": "^18.3.1",
    "react-native": "0.74.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "typescript": "^5.7.3",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/android": "^6.2.0",
    "@capacitor/ios": "^6.2.0"
  }
}
